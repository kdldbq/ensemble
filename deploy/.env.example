# Production env file. Copy to deploy/.env and fill in secrets.
# DO NOT commit deploy/.env — only this .example file.

# Postgres
POSTGRES_DB=ensemble
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme-in-production

# Logging
LOG_LEVEL=info  # debug | info | warn | error

# Container image refs (override to pin a tag instead of :latest)
ENSEMBLE_SERVER_IMAGE=ghcr.io/kdldbq/ensemble-server:latest
ENSEMBLE_WEB_IMAGE=ghcr.io/kdldbq/ensemble-web:latest
