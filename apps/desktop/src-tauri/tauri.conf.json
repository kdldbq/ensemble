{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "ensemble",
  "version": "0.0.0",
  "identifier": "com.ensemble.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter @ensemble-sheets/demo dev",
    "devUrl": "http://localhost:5310",
    "beforeBuildCommand": "pnpm --filter @ensemble-sheets/demo build",
    "frontendDist": "../../demo/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ensemble",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "category": "Productivity",
    "shortDescription": "ensemble — collaborative spreadsheet"
  }
}
