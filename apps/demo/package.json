{
  "name": "@ensemble-sheets/demo",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/kdldbq/ensemble.git",
    "directory": "apps/demo"
  },
  "type": "module",
  "scripts": {
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "dev:server": "PORT=5301 DATABASE_URL=postgres://postgres:postgres@localhost:5303/ensemble_dev REDIS_URL=redis://localhost:5304 tsx src/server-runner.ts",
    "dev:web": "vite",
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:web\"",
    "build": "vite build",
    "test": "vitest run",
    "e2e": "playwright test --config e2e/playwright.config.ts",
    "e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@ensemble-sheets/core": "workspace:*",
    "@ensemble-sheets/react": "workspace:*",
    "@ensemble-sheets/server": "workspace:*",
    "@ensemble-sheets/storage-fs": "workspace:*",
    "@univerjs/design": "0.22.1",
    "@univerjs/docs-ui": "0.22.1",
    "@univerjs/sheets-ui": "0.22.1",
    "@univerjs/ui": "0.22.1",
    "hono": "4.6.5",
    "postgres": "3.4.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "xlsx": "0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "1.48.0",
    "@types/node": "20.16.10",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.0",
    "@vitejs/plugin-react": "4.3.2",
    "concurrently": "9.0.1",
    "tsx": "4.19.1",
    "typescript": "5.5.4",
    "vite": "5.4.8",
    "vitest": "2.1.4"
  }
}
