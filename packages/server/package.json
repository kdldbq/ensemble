{
  "name": "@ensemble-sheets/server",
  "version": "0.2.0",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/kdldbq/ensemble.git",
    "directory": "packages/server"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "drizzle"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --enable-source-maps ./dist/db/migrate.js"
  },
  "dependencies": {
    "@hono/node-server": "1.13.2",
    "@hono/node-ws": "1.0.4",
    "drizzle-orm": "0.36.0",
    "hono": "4.6.5",
    "ioredis": "5.4.1",
    "jose": "5.9.6",
    "pino": "^10.3.1",
    "postgres": "3.4.4",
    "ws": "8.18.0",
    "xlsx": "0.18.5"
  },
  "devDependencies": {
    "@ensemble-sheets/storage-fs": "workspace:*",
    "@testcontainers/postgresql": "10.13.2",
    "@testcontainers/redis": "10.13.2",
    "@types/node": "20.16.10",
    "@types/ws": "8.5.12",
    "drizzle-kit": "0.27.0",
    "pino-pretty": "^13.1.3"
  }
}
